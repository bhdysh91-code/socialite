def get_time_ago(date):
    now = datetime.utcnow()
    diff = now - date
    
    seconds = diff.total_seconds()
    minutes = seconds // 60
    hours = minutes // 60
    days = hours // 24
    
    if seconds < 60:
        return 'الآن'
    elif minutes < 60:
        return f'منذ {int(minutes)} دقيقة'
    elif hours < 24:
        return f'منذ {int(hours)} ساعة'
    elif days < 7:
        return f'منذ {int(days)} يوم'
    else:
        return f'منذ {int(days // 7)} أسبوع'

