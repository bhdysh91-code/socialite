@app.route('/api/posts')
@login_required
def api_get_posts():
    posts = Post.query.order_by(Post.created_at.desc()).all()
    return jsonify([p.to_dict(current_user.id) for p in posts])

@app.route('/api/posts', methods=['POST'])
@login_required
def api_create_post():
    data = request.get_json()
    text = data.get('text', '').strip()
    image_data = data.get('image')
    video_data = data.get('video')
    
    if not text and not image_data and not video_data:
        return jsonify({'error': 'نص أو صورة أو فيديو مطلوب'}), 400
    
    image_path = None
    video_path = None
    
    if image_data:
        try:
            if ',' in image_data:
                image_data = image_data.split(',')[1]
            image_bytes = base64.b64decode(image_data)
            filename = f"post_{datetime.utcnow().strftime('%Y%m%d%H%M%S')}_{current_user.id}.jpg"
            filepath = os.path.join('static/uploads/posts', filename)
            with open(filepath, 'wb') as f:
                f.write(image_bytes)
            image_path = f'/static/uploads/posts/{filename}'
        except Exception as e:
            print(f"Error saving image: {e}")
    
    if video_data:
        try:
            if ',' in video_data:
                video_data = video_data.split(',')[1]
            video_bytes = base64.b64decode(video_data)
            filename = f"video_{datetime.utcnow().strftime('%Y%m%d%H%M%S')}_{current_user.id}.mp4"
            filepath = os.path.join('static/uploads/posts', filename)
            with open(filepath, 'wb') as f:
                f.write(video_bytes)
            video_path = f'/static/uploads/posts/{filename}'
        except Exception as e:
            print(f"Error saving video: {e}")
    
    post = Post(
        user_id=current_user.id,
        text=text or '📸 محتوى جديد',
        image=image_path,
        video=video_path,
        created_at=datetime.utcnow()
    )
    db.session.add(post)
    db.session.commit()
    
    return jsonify(post.to_dict(current_user.id))

@app.route('/api/posts/<int:post_id>/like', methods=['POST'])
@login_required
def api_toggle_like(post_id):
    post = Post.query.get_or_404(post_id)
    
    like = Like.query.filter_by(user_id=current_user.id, post_id=post_id).first()
    
    if like:
        db.session.delete(like)
        liked = False
    else:
        like = Like(user_id=current_user.id, post_id=post_id)
        db.session.add(like)
        liked = True
        if post.user_id != current_user.id:
            notif = Notification(
                user_id=post.user_id,
                type='like',
                from_user_id=current_user.id,
                post_id=post_id,
                message=f'{current_user.full_name} أعجب بمنشورك',
                created_at=datetime.utcnow()
            )
            db.session.add(notif)
            db.session.commit()
    
    db.session.commit()
    
    return jsonify({
        'liked': liked,
        'likes_count': post.get_likes_count()
    })

@app.route('/api/posts/<int:post_id>/comment', methods=['POST'])
@login_required
def api_add_comment(post_id):
    data = request.get_json()
    text = data.get('text', '').strip()
    
    if not text:
        return jsonify({'error': 'نص التعليق مطلوب'}), 400
    
    comment = Comment(
        user_id=current_user.id,
        post_id=post_id,
        text=text,
        created_at=datetime.utcnow()
    )
    db.session.add(comment)
    db.session.commit()
    
    post = Post.query.get(post_id)
    if post and post.user_id != current_user.id:
        notif = Notification(
            user_id=post.user_id,
            type='comment',
            from_user_id=current_user.id,
            post_id=post_id,
            message=f'{current_user.full_name} علق على منشورك',
            created_at=datetime.utcnow()
        )
        db.session.add(notif)
        db.session.commit()
    
    return jsonify(comment.to_dict())

@app.route('/api/posts/<int:post_id>/comments')
@login_required
def api_get_comments(post_id):
    comments = Comment.query.filter_by(post_id=post_id).order_by(Comment.created_at.desc()).limit(20).all()
    return jsonify([c.to_dict() for c in comments])

# ================================================================
# API - الأصدقاء (الإصلاح الكامل)
# ================================================================
@app.route('/api/friends/accept/<int:request_id>', methods=['POST'])
@login_required
def api_accept_friend_request(request_id):
    """قبول طلب صداقة - نسخة نهائية مضمونة"""
    # جلب الطلب من قاعدة البيانات
    friendship = Friendship.query.get(request_id)
    
    # التحقق من وجود الطلب
    if not friendship:
        return jsonify({'error': 'الطلب غير موجود'}), 404
    
    # التحقق من أن الطلب موجه للمستخدم الحالي
    if friendship.friend_id != current_user.id:
        return jsonify({'error': 'غير مصرح'}), 403
    
    # التحقق من أن الطلب لا يزال معلقاً
    if friendship.status != 'pending':
        return jsonify({'error': 'الطلب تم معالجته مسبقاً'}), 400
    
    # تحديث حالة الطلب إلى مقبول
    friendship.status = 'accepted'
    db.session.commit()
    
    # إشعار للمرسل
    notif = Notification(
        user_id=friendship.user_id,
        type='friend_accepted',
        from_user_id=current_user.id,
        message=f'{current_user.full_name} قبل طلب صداقتك',
        created_at=datetime.utcnow()
    )
    db.session.add(notif)
    db.session.commit()
    
    return jsonify({'success': True, 'message': 'تم قبول الطلب'})

# ================================================================
# ✅ دالة قبول طلب الصداقة - الإصلاح النهائي
# ================================================================

@app.route('/api/friends/accept/<int:request_id>', methods=['POST'])
@login_required
def api_accept_friend_request(request_id):
    try:
        # جلب الطلب من قاعدة البيانات
        friendship = Friendship.query.get(request_id)
        
        # التحقق من وجود الطلب
        if not friendship:
            return jsonify({'error': 'الطلب غير موجود'}), 404
        
        # التحقق من أن الطلب موجه للمستخدم الحالي
        if friendship.friend_id != current_user.id:
            return jsonify({'error': 'غير مصرح'}), 403
        
        # التحقق من أن الطلب لا يزال معلقاً
        if friendship.status != 'pending':
            return jsonify({'error': 'الطلب تم معالجته مسبقاً'}), 400
        
        # تحديث حالة الطلب إلى مقبول
        friendship.status = 'accepted'
        db.session.commit()
        
        # إشعار للمرسل
        notif = Notification(
            user_id=friendship.user_id,
            type='friend_accepted',
            from_user_id=current_user.id,
            message=f'{current_user.full_name} قبل طلب صداقتك',
            created_at=datetime.utcnow()
        )
        db.session.add(notif)
        db.session.commit()
        
        return jsonify({'success': True, 'message': 'تم قبول الطلب'})
        
    except Exception as e:
        print(f"Error accepting friend: {e}")
        return jsonify({'error': str(e)}), 500

@app.route('/api/friends/reject/<int:request_id>', methods=['POST'])
@login_required
def api_reject_friend_request(request_id):
    try:
        friendship = Friendship.query.get(request_id)
        
        if not friendship:
            return jsonify({'error': 'الطلب غير موجود'}), 404
        
        if friendship.friend_id != current_user.id:
            return jsonify({'error': 'غير مصرح'}), 403
        
        db.session.delete(friendship)
        db.session.commit()
        
        return jsonify({'success': True, 'message': 'تم رفض الطلب'})
        
    except Exception as e:
        print(f"Error rejecting friend: {e}")
        return jsonify({'error': str(e)}), 500

@app.route('/api/friends/remove/<int:user_id>', methods=['POST'])
@login_required
def api_remove_friend(user_id):
    try:
        friendship = Friendship.query.filter(
            ((Friendship.user_id == current_user.id) & (Friendship.friend_id == user_id)) |
            ((Friendship.user_id == user_id) & (Friendship.friend_id == current_user.id)),
            Friendship.status == 'accepted'
        ).first()
        
        if not friendship:
            return jsonify({'error': 'ليس صديقاً'}), 400
        
        db.session.delete(friendship)
        db.session.commit()
        
        return jsonify({'success': True, 'message': 'تم إزالة الصديق'})
        
    except Exception as e:
        print(f"Error removing friend: {e}")
        return jsonify({'error': str(e)}), 500

# ================================================================
# API - تغيير الصورة الشخصية
# ================================================================

@app.route('/api/user/avatar', methods=['POST'])
@login_required
def api_change_avatar():
    try:
        data = request.get_json()
        image_data = data.get('avatar')
        
        if not image_data:
            return jsonify({'error': 'الصورة مطلوبة'}), 400
        
        if ',' in image_data:
            image_data = image_data.split(',')[1]
        
        image_bytes = base64.b64decode(image_data)
        filename = f"avatar_{current_user.id}_{datetime.utcnow().strftime('%Y%m%d%H%M%S')}.jpg"
        filepath = os.path.join('static/uploads/avatars', filename)
        
        with open(filepath, 'wb') as f:
            f.write(image_bytes)
        
        current_user.avatar = f'/static/uploads/avatars/{filename}'
        db.session.commit()
        
        return jsonify({'success': True, 'avatar': current_user.avatar})
        
    except Exception as e:
        print(f"Error uploading avatar: {e}")
        return jsonify({'error': str(e)}), 500

# ================================================================
# API - الإشعارات
# ================================================================

@app.route('/api/notifications')
@login_required
def api_get_notifications():
    notifs = Notification.query.filter_by(user_id=current_user.id).order_by(
        Notification.created_at.desc()
    ).limit(50).all()
    
    for n in notifs:
        n.read = True
    db.session.commit()
    
    return jsonify([{
        'id': n.id,
        'type': n.type,
        'message': n.message,
        'read': n.read,
        'created_at': n.created_at.isoformat() if n.created_at else None,
        'from_user': n.from_user.to_dict() if n.from_user else None
    } for n in notifs])

@app.route('/api/notifications/unread')
@login_required
def api_unread_notifications():
    count = Notification.query.filter_by(user_id=current_user.id, read=False).count()
    return jsonify({'count': count})

@app.route('/api/search')
@login_required
def api_search():
    query = request.args.get('q', '').strip()
    
    if len(query) < 2:
        return jsonify([])
    
    users = User.query.filter(
        (User.username.contains(query)) | (User.full_name.contains(query)),
        User.id != current_user.id
    ).limit(10).all()
    
    return jsonify([u.to_dict() for u in users])

